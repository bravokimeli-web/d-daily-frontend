# Backend API URL (absolute https://… in production builds, e.g. Vercel).
# Do not use "/api" alone — that posts to the static site and returns HTTP 405.
# Dev: omit to use Vite proxy to localhost:5000, or set a full URL.
VITE_API_URL=http://localhost:5000/api

# Paystack public key (for frontend Paystack popup/inline, optional)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here
